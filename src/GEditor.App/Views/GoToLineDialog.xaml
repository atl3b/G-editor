<Window x:Class="GEditor.App.Views.GoToLineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="跳转到行号"
        Width="380"
        Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BrushBgDark}"
        Foreground="{StaticResource BrushTextPrimary}"
        FontFamily="{StaticResource UiFontFamily}"
        WindowStyle="SingleBorderWindow"
        FocusManager.FocusedElement="{Binding ElementName=LineNumberTextBox}">

    <!--
    ╔══════════════════════════════════════╗
    ║   Go To Line Dialog - Dark Theme    ║
    ║   Premium Dialog Style               ║
    ╚══════════════════════════════════════╝
    -->

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题说明 -->
        <TextBlock Grid.Row="0" 
                   Text="输入目标行号:" 
                   VerticalAlignment="Center" 
                   Foreground="{StaticResource BrushTextSecondary}"
                   FontWeight="SemiBold"
                   FontSize="12.5"
                   Margin="0,0,0,10"/>

        <!-- 输入区域 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
            
            <!-- 行号输入框 - Premium Dark Input -->
            <TextBox x:Name="LineNumberTextBox"
                     Width="130"
                     VerticalAlignment="Center"
                     Padding="8,6"
                     FontFamily="{StaticResource MonoFontFamily}"
                     FontSize="13"
                     Background="#0F1419"
                     Foreground="{StaticResource BrushTextPrimary}"
                     BorderBrush="#2F3A47"
                     CaretBrush="{StaticResource BrushAccentPrimary}">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrushAccentPrimary}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- 范围提示文字 -->
            <TextBlock Text="(1" 
                       VerticalAlignment="Center" 
                       Foreground="#5C6370"
                       FontSize="12"
                       Margin="5,0,2,0"/>
            
            <TextBlock x:Name="MaxLineText" 
                       VerticalAlignment="Center" 
                       Foreground="{StaticResource BrushAccentPrimary}" 
                       FontWeight="SemiBold"
                       FontSize="12"
                       Margin="0,0,2,0"/>
            
            <TextBlock Text=")" 
                       VerticalAlignment="Center" 
                       Foreground="#5C6370"
                       FontSize="12"/>
        </StackPanel>

        <!-- 弹性空间 -->
        <Grid Grid.Row="2"/>

        <!-- 按钮组 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            
            <!-- 确定按钮 - Primary Accent -->
            <Button Content="确定" 
                    IsDefault="True" 
                    Click="OkButton_Click" 
                    Padding="20,6" 
                    MinWidth="90" 
                    Margin="0,0,10,0"
                    FontWeight="SemiBold"
                    FontSize="11.5">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                        <Setter Property="Background" Value="#00D4AA18"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushAccentPrimary}"/>
                        <Setter Property="BorderBrush" Value="#00D4AA40"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00D4AA28"/>
                                <Setter Property="BorderBrush" Value="#00D4AA60"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00D4AA35"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <!-- 取消按钮 -->
            <Button Content="取消" 
                    IsCancel="True" 
                    Padding="20,6" 
                    MinWidth="90"
                    FontWeight="SemiBold"
                    FontSize="11.5"
                    Style="{StaticResource ToolbarButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
