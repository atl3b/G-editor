<Window x:Class="GEditor.App.Views.GoToLineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="跳转到行号"
        Width="350"
        Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FocusManager.FocusedElement="{Binding ElementName=LineNumberTextBox}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="输入目标行号:" VerticalAlignment="Center" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="LineNumberTextBox"
                     Width="120"
                     VerticalAlignment="Center"
                     Padding="4,2"/>
            <TextBlock Text="(1" VerticalAlignment="Center" Margin="4,0"/>
            <TextBlock x:Name="MaxLineText" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text=")" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" IsDefault="True" Click="OkButton_Click" Padding="16,4" MinWidth="80" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Padding="16,4" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
